# Production — Hetzner paylaşımlı VPS
# Sunucuda: cp deploy/.env.production.example deploy/.env && nano deploy/.env

# ── TTEN Games paylaşımlı nginx ──
KILIC_TTEN_NETWORK=ttengamesstudio_ttengamesstudio-network

# ── Host portları (TTEN 3000/4000, Portfolio 3100–3102/5433/6380 ile çakışmaz) ──
FRONTEND_HOST_PORT=3200
ADMIN_HOST_PORT=3201
API_HOST_PORT=3202
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6381

# ── Domain URL'leri ──
FRONTEND_URL=https://kiliccoffeeroaster.com.tr
ADMIN_URL=https://admin.kiliccoffeeroaster.com.tr
API_URL=https://api.kiliccoffeeroaster.com.tr
NEXT_PUBLIC_SITE_URL=https://kiliccoffeeroaster.com.tr
NEXT_PUBLIC_ADMIN_URL=https://admin.kiliccoffeeroaster.com.tr
NEXT_PUBLIC_API_URL=https://api.kiliccoffeeroaster.com.tr
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Frontend/admin container SSR → Docker ağı (compose zaten set eder; dokümantasyon)
# API_INTERNAL_URL=http://api:4000

# ── API / JWT ──
API_PORT=4000
JWT_SECRET=degistir-uzun-rastgele-secret-uret
JWT_EXPIRES_IN=7d
ADMIN_ALLOWLIST=emrekilic19983@gmail.com

# Dump import sonrası false bırakın. Boş DB + şema yoksa ilk boot için true.
DATABASE_SYNCHRONIZE=false

# ── PostgreSQL ──
POSTGRES_USER=kilic
POSTGRES_PASSWORD=degistir-guclu-sifre
POSTGRES_DB=kiliccoffeeroaster

# ── Google OAuth ──
# Console'a ekleyin:
#   https://api.kiliccoffeeroaster.com.tr/auth/google/callback
#   https://api.kiliccoffeeroaster.com.tr/auth/google/admin/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.kiliccoffeeroaster.com.tr/auth/google/callback
GOOGLE_ADMIN_CALLBACK_URL=https://api.kiliccoffeeroaster.com.tr/auth/google/admin/callback

# ── Ödeme ──
PAYMENT_PROVIDER=paytr
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_DEBUG_ON=1
PAYTR_NO_INSTALLMENT=0
PAYTR_MAX_INSTALLMENT=0
# PayTR bildirim URL: https://api.kiliccoffeeroaster.com.tr/payments/paytr/callback

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── AWS S3 (boşsa yerel uploads volume) ──
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_CDN_URL=

# ── Redis (compose override eder; burada dokümantasyon) ──
REDIS_URL=redis://redis:6379
BULL_BOARD_PATH=/admin/queues

# ── Mail ──
MAIL_FROM="Kılıç Coffee Roaster <info@kiliccoffeeroaster.com.tr>"
MAIL_HOST=
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=info@kiliccoffeeroaster.com.tr
MAIL_PASS=

# ── WhatsApp ──
WHATSAPP_PROVIDER=console
WHATSAPP_FROM=+905412147963
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=

# ── Pricing ──
TAX_RATE_PERCENT=20
TAX_INCLUDED=true
DEFAULT_SHIPPING_FEE=89.90
FREE_SHIPPING_OVER=0
ABANDONED_CART_HOURS=4
ABANDONED_CART_SECOND_HOURS=24
LOW_STOCK_THRESHOLD=10
LOW_STOCK_ALERT_EMAILS=
LOW_STOCK_SCAN_INTERVAL_HOURS=24
MARKETPLACE_SYNC_ENABLED=true
MARKETPLACE_SYNC_INTERVAL_MINUTES=60
