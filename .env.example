# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kiliccoffeeroaster
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_URL=postgresql://kilic:kilic_secret@localhost:5432/kiliccoffeeroaster

# API
API_PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
ADMIN_ALLOWLIST=emrekilic19983@gmail.com

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
GOOGLE_ADMIN_CALLBACK_URL=http://localhost:4000/auth/google/admin/callback

# Ödeme sağlayıcı: paytr | iyzico (boş = PayTR bilgisi varsa paytr)
PAYMENT_PROVIDER=paytr

# PayTR (Mağaza Paneli → Bilgi)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_DEBUG_ON=1
PAYTR_NO_INSTALLMENT=0
PAYTR_MAX_INSTALLMENT=0
# Bildirim URL (PayTR panele yazın): {API_URL}/payments/paytr/callback

# iyzico (yedek / alternatif)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# AWS S3 (görsel depolama)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_CDN_URL=

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
BULL_BOARD_PATH=/admin/queues

# Email (kendi SMTP / hosting mail hesabı)
# Yayında: info@kiliccoffeeroaster.com.tr
MAIL_FROM=Kılıç Coffee Roaster <info@kiliccoffeeroaster.com.tr>
MAIL_HOST=
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=info@kiliccoffeeroaster.com.tr
MAIL_PASS=

# WhatsApp Business iş hattı (+905412147963)
# Müşteri sohbeti: telefonda WhatsApp Business uygulaması
# Otomatik sipariş bildirimi: Meta Cloud API (console | meta)
# Not: Aynı numara App + Cloud API’de birlikte kullanılamaz
WHATSAPP_PROVIDER=console
WHATSAPP_FROM=+905412147963
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=

# Pricing / tax / shipping
TAX_RATE_PERCENT=20
TAX_INCLUDED=true
DEFAULT_SHIPPING_FEE=89.90
# 0 = ücretsiz kargo eşiği kapalı
FREE_SHIPPING_OVER=0

# Prod’da mock kargo oluşturmak için true (varsayılan: production’da kapalı)
# SHIPPING_ALLOW_MOCK=false

# Abandoned cart e-posta (saat; giriş yapmış kullanıcı veya misafir e-posta)
ABANDONED_CART_HOURS=4
# 1. hatırlatmadan kaç saat sonra 2. hatırlatma
ABANDONED_CART_SECOND_HOURS=24

# Düşük stok uyarıları
LOW_STOCK_THRESHOLD=10
# Opsiyonel ekstra alıcılar (virgülle); boşsa ADMIN_ALLOWLIST + DB allowlist
LOW_STOCK_ALERT_EMAILS=
LOW_STOCK_SCAN_INTERVAL_HOURS=24

# Pazaryeri otomatik sync (aktif hesaplar)
MARKETPLACE_SYNC_ENABLED=true
MARKETPLACE_SYNC_INTERVAL_MINUTES=60
# Platform API taban URL’leri (opsiyonel; stage için değiştirin)
# TRENDYOL_API_BASE_URL=https://stageapigw.trendyol.com/integration
# HEPSIBURADA_LISTING_BASE_URL=https://listing-external.hepsiburada.com
# HEPSIBURADA_OMS_BASE_URL=https://oms-external.hepsiburada.com
# N11_API_BASE_URL=https://api.n11.com
# N11_INTEGRATOR_NAME=KilicCoffeeRoaster

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_CDN_URL=
# Google Search Console site verification meta (opsiyonel)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Analitik (çerez onayı analytics/marketing true olunca yüklenir)
NEXT_PUBLIC_GA4_ID=
# GTM doluysa GA4 script’i atlanır (GTM içinden yönetin)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
